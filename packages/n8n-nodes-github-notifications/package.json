{
  "name": "n8n-nodes-github-notifications",
  "version": "1.0.0",
  "description": "n8n node to list GitHub notifications",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "github",
    "notifications"
  ],
  "license": "MIT",
  "author": {
    "name": "Jörg Thalheim",
    "email": "joerg@thalheim.io"
  },
  "scripts": {
    "build": "tsc && find nodes -name '*.svg' -o -name '*.node.json' | while read f; do cp \"$f\" \"dist/$f\"; done",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/GitHubNotifications/GitHubNotifications.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
